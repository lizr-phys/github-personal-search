# Core
NODE_ENV=development
APP_URL=http://localhost:3000
GPS_DEMO_MODE=true
GPS_RUNTIME_STORE=file
GPS_DATA_FILE=.data/gps-demo.json
GPS_DEMO_FALLBACK=true
GPS_PERSIST_GITHUB_TO_POSTGRES=false
SESSION_SECRET=replace-with-at-least-32-random-characters
TOKEN_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key

# PostgreSQL / pgvector
DATABASE_URL=postgres://gps:gps@localhost:5432/gps

# Redis / worker (optional in demo mode)
REDIS_URL=redis://localhost:6379

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Optional AI providers; evidence templates and local semantic mode are used when empty.
# Never commit a real API key. The DeepSeek endpoint is called server-side only.
AI_PROVIDER=local
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
EMBEDDING_API_KEY=

# Mail. Mailpit defaults are used by Docker Compose.
MAIL_PROVIDER=preview
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=GPS <gps@localhost>

# Development only
GPS_ENABLE_TEST_RESET=false
GPS_SPONSORSHIP_ENABLED=false
LOG_LEVEL=info
