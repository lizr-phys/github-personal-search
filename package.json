{
  "name": "github-personal-search",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run tests/unit tests/integration --coverage --coverage.include=\"src/**/*.{ts,tsx}\" --coverage.reporter=text --coverage.reporter=json-summary",
    "test:all": "vitest run",
    "test:e2e": "playwright test",
    "test:algorithm": "tsx tools/evaluate-algorithms.ts",
    "test:performance": "node tools/benchmark-api.mjs",
    "test:load": "node tools/load-test.mjs",
    "test:scale": "tsx tools/scale-benchmark.ts",
    "test:e2e:install": "playwright install chromium",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed": "tsx db/seed.ts",
    "db:reset": "tsx db/reset.ts",
    "worker": "tsx workers/index.ts",
    "format": "prettier --write .",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:integration && pnpm build"
  },
  "dependencies": {
    "bullmq": "5.80.8",
    "drizzle-orm": "0.45.2",
    "ioredis": "5.11.1",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
